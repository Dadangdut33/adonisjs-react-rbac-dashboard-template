{
  "extends": "@adonisjs/tsconfig/tsconfig.client.json",
  "compilerOptions": {
    "module": "ESNext",
    "jsx": "react-jsx",
    "paths": {
      "~/*": ["./*"],
      "@app/*": ["../app/*"],
      "#types/*": ["../shared/types/*"],
      "#transformers/*": ["../app/transformers/*"],
      "#middleware/*": ["../app/middleware/*"],
      "~/generated/*": ["../.adonisjs/client/*"],
      "~data": ["../.adonisjs/client/data.d.ts"],
      "~registry": ["../.adonisjs/client/registry/index.ts"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
